generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  VIEWER
}

enum DayKey {
  mon
  tue
  wed
  thu
  fri
  sat
  sun
}

model Shop {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  employees   Employee[]
  shiftLogs   ShiftLog[]
  eodReports  EodReport[]
  cashCounts  CashCount[]
  rosterWeeks RosterWeek[]
  auditLogs   AuditLog[]
}

model User {
  id           String     @id @default(cuid())
  shopId       String
  email        String     @unique
  passwordHash String
  name         String?
  role         Role       @default(MANAGER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  shop         Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sessions     Session[]
  auditLogs    AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Employee {
  id                String        @id @default(cuid())
  shopId            String
  name              String
  role              String        @default("Staff")
  hourlyRate        Float
  saturdayRate      Float?
  sundayRate        Float?
  publicHolidayRate Float?
  availableDays     String        @default("mon,tue,wed,thu,fri,sat,sun")
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  shop              Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shiftLogs         ShiftLog[]
  rosterSlots       RosterSlot[]
}

model ShiftLog {
  id         String   @id @default(cuid())
  shopId     String
  employeeId String
  date       String
  hours      Float
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([shopId, date])
}

model EodReport {
  id               String   @id @default(cuid())
  shopId           String
  date             String
  grossSales       Float
  cardSales        Float
  cashSales        Float
  refunds          Float    @default(0)
  transactionCount Int      @default(0)
  notes            String?
  tillCash         Float    @default(0)
  expensesAmount   Float    @default(0)
  expenseNotes     String?
  urgentStock      String?
  staffSignature   String?
  floatTarget      Float    @default(1100)
  denomCounts      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
}

model CashCount {
  id           String   @id @default(cuid())
  shopId       String
  date         String
  openingFloat Float
  countedCash  Float
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
}

model RosterWeek {
  id          String        @id @default(cuid())
  shopId      String
  weekStart   String
  slotsPerDay Int           @default(1)
  published   Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  shop        Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  slots       RosterSlot[]

  @@unique([shopId, weekStart])
}

model RosterSlot {
  id           String     @id @default(cuid())
  rosterWeekId String
  day          DayKey
  slotIndex    Int
  employeeId   String?
  start        String     @default("10:00")
  end          String     @default("18:00")
  rosterWeek   RosterWeek @relation(fields: [rosterWeekId], references: [id], onDelete: Cascade)
  employee     Employee?  @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@unique([rosterWeekId, day, slotIndex])
}

model AuditLog {
  id         String   @id @default(cuid())
  shopId     String
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   String?
  createdAt  DateTime @default(now())
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
}
